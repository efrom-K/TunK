{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VPN Client",
  "identifier": "com.vpn.client.windows11",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
        "windows": [
          {
            "title": "VPN Client",
            "width": 1024,
            "height": 768,
            "resizable": true,
            "fullscreen": false,
            "center": true,
            "decorations": true,
            "transparent": false
          }
        ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true,
      "title": "TunK VPN",
      "tooltip": "TunK VPN Client"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}